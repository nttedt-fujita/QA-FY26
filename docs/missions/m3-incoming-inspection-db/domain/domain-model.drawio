        <!-- ビジネスルール -->
        <mxCell id="rules-title" value="【ビジネスルール】" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=12;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="80" y="440" width="150" height="20" as="geometry" />
        </mxCell>
        <mxCell id="rule1" value="1. ロットは「入荷タイミング」を単位とする&#xa;   → 同じ部品でも入荷日が異なれば別ロット" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="80" y="465" width="350" height="40" as="geometry" />
        </mxCell>
        <mxCell id="rule2" value="2. 検査記録はロット単位で管理&#xa;   → 1ロットに対して複数回の検査が可能" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="80" y="510" width="350" height="40" as="geometry" />
        </mxCell>
        <mxCell id="rule3" value="3. 不問判定には承認者が必要&#xa;   → 検査不合格でも使用可能にする例外処理" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="80" y="555" width="350" height="40" as="geometry" />
        </mxCell>
        <mxCell id="rule4" value="4. M4（工程不良）との連携はlot_idで紐付け&#xa;   → 受入検査品質と工程不良の相関分析が可能" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="80" y="600" width="350" height="40" as="geometry" />
        </mxCell>

