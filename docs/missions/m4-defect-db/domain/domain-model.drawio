        <mxCell id="e1" value="E1: Environment&#xa;環境要因" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;align=center;fontSize=10" vertex="1" parent="1">
          <mxGeometry x="665" y="370" width="80" height="50" as="geometry" />
        </mxCell>

        <!-- 関係線: M3連携 → 工程不良記録 -->
        <mxCell id="rel-m3-defect" value="発生源" style="endArrow=open;html=1;rounded=0;dashed=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.3;entryDx=0;entryDy=0" edge="1" parent="1" source="m3-link" target="defect-record">
          <mxGeometry relative="1" as="geometry" />
