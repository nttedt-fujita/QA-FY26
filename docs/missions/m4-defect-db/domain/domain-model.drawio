          <mxGeometry x="620" y="310" width="80" height="50" as="geometry" />
        </mxCell>
        <mxCell id="m3" value="M3: Material&#xa;材料要因" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;align=center;fontSize=10" vertex="1" parent="1">
          <mxGeometry x="710" y="310" width="80" height="50" as="geometry" />
        </mxCell>
        <mxCell id="m4" value="M4: Method&#xa;方法要因" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;align=center;fontSize=10" vertex="1" parent="1">
          <mxGeometry x="575" y="370" width="80" height="50" as="geometry" />
