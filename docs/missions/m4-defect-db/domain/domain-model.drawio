        </mxCell>

        <!-- 関係線: 工程不良記録 → 原因コード -->
        <mxCell id="rel-defect-cause" value="原因特定" style="endArrow=open;html=1;rounded=0;exitX=1;exitY=0.7;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0" edge="1" parent="1" source="defect-record" target="cause-code-box">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="card-defect-cause" value="N : 0..1" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=10" vertex="1" parent="1">
          <mxGeometry x="450" y="320" width="50" height="20" as="geometry" />
        </mxCell>

        <!-- ビジネスルール -->
        <mxCell id="rules-title" value="【ビジネスルール】" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=12;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="80" y="480" width="150" height="20" as="geometry" />
        </mxCell>
        <mxCell id="rule1" value="1. 不良コードは3階層（大分類-中分類-詳細）で管理&#xa;   → 集計粒度を柔軟に変更可能" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="80" y="505" width="350" height="40" as="geometry" />
        </mxCell>
        <mxCell id="rule2" value="2. 原因コードは4M1E分類（Man/Machine/Material/Method/Environment）&#xa;   → 根本原因分析（RCA）に活用" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="80" y="550" width="420" height="40" as="geometry" />
        </mxCell>
        <mxCell id="rule3" value="3. 原因コードは任意（発生時点では未特定の場合あり）&#xa;   → 後から原因調査結果を追記可能" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="80" y="595" width="350" height="40" as="geometry" />
        </mxCell>
        <mxCell id="rule4" value="4. M3（受入検査）との連携はlot_idで紐付け&#xa;   → 材料起因不良（M3-xx）の場合、サプライヤ品質との相関分析が可能" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="80" y="640" width="450" height="40" as="geometry" />
        </mxCell>

