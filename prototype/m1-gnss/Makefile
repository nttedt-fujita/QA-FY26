# M1-GNSS 評価ツール
# makefiles/*.mk をインクルード

include makefiles/*.mk

# ヘルプ表示（デフォルトターゲット）
.PHONY: help
help:
	@echo "========================================"
	@echo "  M1-GNSS 評価ツール"
	@echo "========================================"
	@echo ""
	@echo "【開発サーバー】"
	@echo "  make dev-backend    バックエンド起動（デバッグログ付き）"
	@echo "  make dev-frontend   フロントエンド起動"
	@echo "  make dev            両方起動（バックグラウンド）"
	@echo "  make stop-all       全プロセス停止"
	@echo ""
	@echo "【テスト・ビルド】"
	@echo "  make test           バックエンドテスト"
	@echo "  make test-verbose   テスト（出力あり）"
	@echo "  make build          リリースビルド"
	@echo "  make clean          ビルド成果物削除"
	@echo ""
	@echo "【API呼び出し（デバッグ用）】※DEVICE=/dev/ttyUSB1 でデバイス変更可"
	@echo "  make devices        装置一覧 (GET)"
	@echo "  make connect        装置接続 (POST) [DEVICE=/dev/ttyUSB0]"
	@echo "  make disconnect     装置切断 (POST)"
	@echo "  make message-scan   定期出力確認 (GET)"
	@echo "  make reset-config   設定リセット (POST)"
	@echo "  make gnss-state     GNSS状態 (GET)"
	@echo "  make lots           ロット一覧 (GET)"
	@echo "  make create-lot     テストロット作成 (POST)"
	@echo "  make inspect LOT_ID=1  検査実行 (POST)"
	@echo "  make inspections    検査履歴 (GET)"
	@echo "  make health         ヘルスチェック (GET)"
	@echo ""
	@echo "【RTK関連】"
	@echo "  make rtk-debug      RTKデバッグ一括（接続+ポーリング）"
	@echo "  make rtk-connect    NTRIP接続"
	@echo "  make rtk-disconnect NTRIP切断"
	@echo "  make rtk-poll       gnss-state 5回ポーリング"
	@echo ""
	@echo "【Docker（今後対応）】"
	@echo "  make docker-build   イメージビルド"
	@echo "  make docker-run     コンテナ起動（USB対応）"
	@echo ""
