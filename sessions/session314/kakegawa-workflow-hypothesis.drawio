                    <mxGeometry x="595" y="365" width="290" height="30" as="geometry"/>
                </mxCell>
                <mxCell id="s5d" value="★青塗りつぶし = 自動計算 [A — PSI凡例で確認]&#xa;&#xa;在庫（受注ベース残）= 前月在庫 + 入庫 − 受注数&#xa;在庫（納品ベース残）= 前月在庫 + 入庫 − 納品数&#xa;在庫（出荷予測ベース残）= 前月在庫 + 入庫 − 出荷予測" style="text;html=1;fontSize=10;align=left;fontColor=#333;" parent="1" vertex="1">
