                </mxCell>
                <mxCell id="formula-box" value="&lt;b&gt;計算式の詳細&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;font style=&#39;font-size:10px&#39;&gt;&lt;b&gt;出庫予定(月)&lt;/b&gt; = Σ(員数[製品i] × 生産台数[製品i][月])&lt;br&gt;　製品i = AC102, BB102, 粒剤装置&lt;br&gt;　製造先 = ナカヨ + 渡辺製作所 + SL福島&lt;br&gt;&lt;br&gt;&lt;b&gt;在庫数(初月)&lt;/b&gt; = 棚卸在庫 + eDT→ナカヨ出庫調整&lt;br&gt;&lt;b&gt;在庫数(N+1月)&lt;/b&gt; = 在庫数(N月) + 入庫数(N+1月) - 出庫予定(N+1月)&lt;br&gt;&lt;br&gt;&lt;b&gt;アラート&lt;/b&gt; = 在庫数 ≦ 0 の月を色分け表示&lt;br&gt;　■ = 全拠点合計で欠品&lt;br&gt;　▨ = ナカヨ単独で欠品&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#CCCCCC;align=left;spacingLeft=10;spacingTop=5;" parent="1" vertex="1">
                    <mxGeometry x="760" y="560" width="350" height="220" as="geometry"/>
                </mxCell>
