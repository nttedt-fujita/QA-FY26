                </mxCell>
                <mxCell id="tanaoroshi" value="&lt;b&gt;棚卸表&lt;/b&gt;&lt;br&gt;&lt;font style=&#39;font-size:10px&#39;&gt;eDT: 棚卸表_eDT_260114&lt;br&gt;ナカヨ: 棚卸表_ナカヨ_251226&lt;br&gt;&lt;br&gt;部品ごとの&lt;b&gt;実在庫数&lt;/b&gt;（時点スナップショット）&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;align=left;spacingLeft=10;" parent="1" vertex="1">
                    <mxGeometry x="40" y="240" width="250" height="100" as="geometry"/>
                </mxCell>
                <mxCell id="bom" value="&lt;b&gt;BOM（部品表）&lt;/b&gt;&lt;br&gt;&lt;font style=&#39;font-size:10px&#39;&gt;AC102: A25-BOM-7&lt;br&gt;BB102: B25-BOM-01&lt;br&gt;粒剤装置: P13-AC102-BOM-3&lt;br&gt;&lt;br&gt;製品1台あたりの&lt;b&gt;部品員数&lt;/b&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;align=left;spacingLeft=10;" parent="1" vertex="1">
                    <mxGeometry x="40" y="120" width="250" height="110" as="geometry"/>
                </mxCell>
                <mxCell id="seisan" value="&lt;b&gt;生産計画&lt;/b&gt;&lt;br&gt;&lt;font style=&#39;font-size:10px&#39;&gt;製造委託先ごとの月別生産台数&lt;br&gt;・ナカヨ&lt;br&gt;・渡辺製作所&lt;br&gt;・スカイリンク福島&lt;br&gt;&lt;br&gt;例: AC102 ナカヨ 1月=50台&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;align=left;spacingLeft=10;" parent="1" vertex="1">
                    <mxGeometry x="40" y="380" width="250" height="130" as="geometry"/>
                </mxCell>
                <mxCell id="edt-nyuko" value="&lt;b&gt;eDT入庫数&lt;/b&gt;&lt;br&gt;&lt;font style=&#39;font-size:10px&#39;&gt;部品ごとの月別入庫予定数&lt;br&gt;（発注→納品の実績・予定）&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;align=left;spacingLeft=10;" parent="1" vertex="1">
                    <mxGeometry x="40" y="530" width="250" height="70" as="geometry"/>
                </mxCell>
                <mxCell id="edt-nakayo" value="&lt;b&gt;eDT→ナカヨ出庫数&lt;/b&gt;&lt;br&gt;&lt;font style=&#39;font-size:10px&#39;&gt;eDTからナカヨへの部品出庫数&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;align=left;spacingLeft=10;" parent="1" vertex="1">
                    <mxGeometry x="40" y="620" width="250" height="60" as="geometry"/>
                </mxCell>
                <mxCell id="calc-group" value="計算処理（自動）" style="text;html=1;fontSize=14;fontStyle=1;fontColor=#333333;" parent="1" vertex="1">
                    <mxGeometry x="430" y="90" width="250" height="30" as="geometry"/>
                </mxCell>
                <mxCell id="buhin-master" value="&lt;b&gt;部品リストマスター&lt;/b&gt;&lt;br&gt;&lt;font style=&#39;font-size:10px&#39;&gt;BOMから自動生成&lt;br&gt;部品番号 → 員数マッピング&lt;br&gt;(AC102用, BB102用, 粒剤用)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" parent="1" vertex="1">
                    <mxGeometry x="400" y="130" width="280" height="80" as="geometry"/>
                </mxCell>
                <mxCell id="shukko-calc" value="&lt;b&gt;出庫予定(ALL)&lt;/b&gt;&lt;br&gt;&lt;font style=&#39;font-size:10px&#39;&gt;&lt;b&gt;計算式:&lt;/b&gt;&lt;br&gt;月別出庫数 = &lt;br&gt;　員数(AC102) × 生産台数(AC102)&lt;br&gt;+ 員数(BB102) × 生産台数(BB102)&lt;br&gt;+ 員数(粒剤) × 生産台数(粒剤)&lt;br&gt;&lt;br&gt;※ナカヨ版は(ナカヨ)のみで計算&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" parent="1" vertex="1">
                    <mxGeometry x="400" y="240" width="280" height="150" as="geometry"/>
                </mxCell>
                <mxCell id="zaiko-calc" value="&lt;b&gt;在庫数計算処理(ALL)&lt;/b&gt;&lt;br&gt;&lt;font style=&#39;font-size:10px&#39;&gt;&lt;b&gt;計算式:&lt;/b&gt;&lt;br&gt;初月在庫 = 棚卸時在庫 + eDT→ナカヨ出庫数&lt;br&gt;翌月在庫 = 前月在庫 + 入庫数 - 出庫予定&lt;br&gt;&lt;br&gt;各月の在庫数を16ヶ月先まで計算&lt;br&gt;&lt;br&gt;※ナカヨ版はナカヨのみの計算&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" parent="1" vertex="1">
                    <mxGeometry x="400" y="420" width="280" height="150" as="geometry"/>
                </mxCell>
                <mxCell id="output-group" value="出力（アラート表示）" style="text;html=1;fontSize=14;fontStyle=1;fontColor=#333333;" parent="1" vertex="1">
                    <mxGeometry x="850" y="90" width="250" height="30" as="geometry"/>
                </mxCell>
                <mxCell id="alert" value="&lt;b&gt;在庫アラート&lt;/b&gt;&lt;br&gt;&lt;font style=&#39;font-size:10px&#39;&gt;在庫数が0以下になる月を検出し&lt;br&gt;色分けで可視化&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" parent="1" vertex="1">
                    <mxGeometry x="830" y="130" width="300" height="60" as="geometry"/>
