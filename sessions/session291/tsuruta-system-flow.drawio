                <mxCell id="color-stripe-text" value="▨ ナカヨ在庫が欠品する月（ナカヨのみベース）" style="text;html=1;fontSize=11;align=left;" parent="1" vertex="1">
                    <mxGeometry x="880" y="240" width="320" height="20" as="geometry"/>
