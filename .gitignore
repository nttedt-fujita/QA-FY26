# バイナリファイル（大容量・git管理不向き）
# 分析結果はmarkdownに書き出し済みなのでgit管理外とする
*.xlsx
*.xls

# PDFは参照用に手元に保持するがpushしない
# ただし目次用の小サイズPDF（1-14-app-note-ublox.pdf）も除外
*.pdf

# PowerPoint（md化済み）
*.pptx

# スクリーンショット画像（分析結果はmarkdownに書き出し済み）
sessions/*/screenshot/

# ビルド成果物
target/
*/target/

# ログファイル
logs/
*.log

# データベースファイル（開発用）
*.db
*.db-shm
*.db-wal

# Python バイトコード
__pycache__/
*.pyc
.env

# CSV（社内業務データ。分析結果はmdに書き出し済みなのでgit管理外）
*.csv
